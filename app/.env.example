# ── Azure CosmosDB ──────────────────────────────────────────
COSMOS_ENDPOINT=https://repairflow.documents.azure.com:443/
COSMOS_KEY=YOUR_COSMOS_PRIMARY_KEY
COSMOS_DB_NAME=repairflow

# ── Azure Blob Storage ───────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=repairflowstorage;AccountKey=YOUR_KEY;EndpointSuffix=core.windows.net
BLOB_CONTAINER_PHOTOS=repair-photos
BLOB_CONTAINER_REPORTS=repair-reports

# ── Azure Communication Services ────────────────────────────
ACS_CONNECTION_STRING=endpoint=https://repairflow-acs.communication.azure.com/;accesskey=YOUR_ACS_KEY
ACS_SENDER_EMAIL=noreply@repairflow.azurecomm.net

# ── Servidor ─────────────────────────────────────────────────
PORT=3000
